{
  "manifest_version": 3,
  "name": "note Markdown Copier",
  "description": "Adds a button to note article pages for copying the visible article as Markdown.",
  "version": "0.1.0",
  "permissions": [
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://note.com/*/n/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "note記事Markdownコピー",
  "description": "noteの記事ページに、表示中の記事をMarkdownとしてコピーするボタンを追加します。",
  "version": "0.1.0",
  "permissions": [
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://note.com/*/n/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
